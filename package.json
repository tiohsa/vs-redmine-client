{
  "name": "redmine-client",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.5.1",
  "publisher": "tiohsa",
  "author": {
    "name": "tiohsa",
    "url": "https://github.com/tiohsa/vs-redmine-client"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tiohsa/vs-redmine-client"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onView:redmine-clientActivityDashboard",
    "onCommand:redmine-client.createTicketFromMarkdownHeader",
    "onCommand:redmine-client.insertRedmineTicketFrontmatter"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "redmine-clientActivity",
          "title": "%viewsContainer.redmineClientActivity.title%",
          "icon": "media/redmine-client-activitybar.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "redmine-client.setApiKey",
        "title": "%command.setApiKey.title%"
      },
      {
        "command": "redmine-client.clearApiKey",
        "title": "%command.clearApiKey.title%"
      },
      {
        "command": "redmine-client.showApiKeyStatus",
        "title": "%command.showApiKeyStatus.title%"
      },
      {
        "command": "redmine-client.refreshProjects",
        "title": "%command.refreshProjects.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.refreshTickets",
        "title": "%command.refreshTickets.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.searchTickets",
        "title": "%command.searchTickets.title%",
        "icon": "$(search)"
      },
      {
        "command": "redmine-client.refreshComments",
        "title": "%command.refreshComments.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.reloadProject",
        "title": "%command.reloadProject.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.reloadTicket",
        "title": "%command.reloadTicket.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.reloadComment",
        "title": "%command.reloadComment.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.selectProject",
        "title": "%command.selectProject.title%"
      },
      {
        "command": "redmine-client.toggleChildProjects",
        "title": "%command.toggleChildProjects.title%"
      },
      {
        "command": "redmine-client.openTicketPreview",
        "title": "%command.openTicketPreview.title%"
      },
      {
        "command": "redmine-client.openExtraTicketEditor",
        "title": "%command.openExtraTicketEditor.title%"
      },
      {
        "command": "redmine-client.configureEditorDefaultSubject",
        "title": "%command.configureEditorDefaultSubject.title%"
      },
      {
        "command": "redmine-client.configureEditorDefaultDescription",
        "title": "%command.configureEditorDefaultDescription.title%"
      },
      {
        "command": "redmine-client.configureEditorDefaultTracker",
        "title": "%command.configureEditorDefaultTracker.title%"
      },
      {
        "command": "redmine-client.configureEditorDefaultPriority",
        "title": "%command.configureEditorDefaultPriority.title%"
      },
      {
        "command": "redmine-client.configureEditorDefaultStatus",
        "title": "%command.configureEditorDefaultStatus.title%"
      },
      {
        "command": "redmine-client.configureEditorDefaultDueDate",
        "title": "%command.configureEditorDefaultDueDate.title%"
      },
      {
        "command": "redmine-client.resetEditorDefaults",
        "title": "%command.resetEditorDefaults.title%"
      },
      {
        "command": "redmine-client.createTicket",
        "title": "%command.createTicket.title%"
      },
      {
        "command": "redmine-client.createTicketFromMarkdownHeader",
        "title": "%command.createTicketFromMarkdownHeader.title%",
        "icon": "$(add)"
      },
      {
        "command": "redmine-client.insertRedmineTicketFrontmatter",
        "title": "%command.insertRedmineTicketFrontmatter.title%",
        "icon": "$(symbol-keyword)"
      },
      {
        "command": "redmine-client.createTicketFromList",
        "title": "%command.createTicketFromList.title%",
        "icon": "$(add)"
      },
      {
        "command": "redmine-client.createChildTicketFromList",
        "title": "%command.createChildTicketFromList.title%",
        "icon": "$(add)"
      },
      {
        "command": "redmine-client.openProjectInBrowser",
        "title": "%command.openProjectInBrowser.title%",
        "icon": "$(link-external)"
      },
      {
        "command": "redmine-client.openTicketInBrowser",
        "title": "%command.openTicketInBrowser.title%",
        "icon": "$(link-external)"
      },
      {
        "command": "redmine-client.openCommentInBrowser",
        "title": "%command.openCommentInBrowser.title%",
        "icon": "$(link-external)"
      },
      {
        "command": "redmine-client.editComment",
        "title": "%command.editComment.title%"
      },
      {
        "command": "redmine-client.addComment",
        "title": "%command.addComment.title%"
      },
      {
        "command": "redmine-client.addCommentFromComments",
        "title": "%command.addCommentFromComments.title%",
        "icon": "$(add)"
      },
      {
        "command": "redmine-client.runOfflineSync",
        "title": "%command.runOfflineSync.title%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "redmine-client.syncUnsyncedFile",
        "title": "%command.syncUnsyncedFile.title%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "redmine-client.configureOfflineSyncMode",
        "title": "%command.configureOfflineSyncMode.title%"
      },
      {
        "command": "redmine-client.revealActiveTicket",
        "title": "%command.revealActiveTicket.title%"
      },
      {
        "command": "redmine-client.focusTicketEditor",
        "title": "%command.focusTicketEditor.title%"
      },
      {
        "command": "redmine-client.syncToRedmine",
        "title": "%command.syncToRedmine.title%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "redmine-client.syncOpenEditor",
        "title": "%command.syncOpenEditor.title%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "redmine-client.syncAllOpenEditors",
        "title": "%command.syncAllOpenEditors.title%",
        "icon": "$(cloud-upload)"
      }
    ],
    "views": {
      "redmine-clientActivity": [
        {
          "id": "redmine-clientActivityDashboard",
          "name": "%view.dashboard.name%",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/item/context": []
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "redmine-client.baseUrl": {
          "type": "string",
          "default": "",
          "description": "%config.baseUrl.description%"
        },
        "redmine-client.ignoreSSLErrors": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.ignoreSSLErrors.markdownDescription%"
        },
        "redmine-client.defaultProjectId": {
          "type": "string",
          "default": "",
          "description": "%config.defaultProjectId.description%"
        },
        "redmine-client.selectedProjectId": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "%config.selectedProjectId.description%"
        },
        "redmine-client.selectedProjectName": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "%config.selectedProjectName.description%"
        },
        "redmine-client.includeChildProjects": {
          "type": "boolean",
          "default": false,
          "description": "%config.includeChildProjects.description%"
        },
        "redmine-client.ticketListLimit": {
          "type": "number",
          "default": 50,
          "description": "%config.ticketListLimit.description%"
        },
        "redmine-client.editorStorageDirectory": {
          "type": "string",
          "default": "",
          "description": "%config.editorStorageDirectory.description%"
        },
        "redmine-client.offlineSyncMode": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "manual"
          ],
          "description": "%config.offlineSyncMode.description%"
        },
        "redmine-client.requestTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "%config.requestTimeoutMs.description%"
        },
        "redmine-client.ticketList.showStatus": {
          "type": "boolean",
          "default": true,
          "description": "%config.ticketList.showStatus.description%"
        },
        "redmine-client.ticketList.showDueDate": {
          "type": "boolean",
          "default": true,
          "description": "%config.ticketList.showDueDate.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "node ./scripts/clean-test-output.js && tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unsafe": "bash ./scripts/vscode-test-nosandbox.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "keytar"
    ]
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.39.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  }
}
