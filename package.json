{
  "name": "redmine-client",
  "displayName": "Redmine Client",
  "description": "Redmine ticket workflows into VS Code",
  "version": "0.1.2",
  "publisher": "your-publisher-id",
  "author": {
    "name": "tiohsa",
    "url": "https://github.com/tiohsa/vs-redmine-client"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tiohsa/vs-redmine-client"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:redmine-clientActivityDashboard",
    "onCommand:redmine-client.refreshTickets",
    "onCommand:redmine-client.refreshProjects",
    "onCommand:redmine-client.collapseAllProjects",
    "onCommand:redmine-client.collapseAllTickets",
    "onCommand:redmine-client.selectProject",
    "onCommand:redmine-client.toggleChildProjects",
    "onCommand:redmine-client.openTicketPreview",
    "onCommand:redmine-client.openExtraTicketEditor",
    "onCommand:redmine-client.reloadTicket",
    "onCommand:redmine-client.reloadComment",
    "onCommand:redmine-client.configureTicketPriorityFilter",
    "onCommand:redmine-client.configureTicketTitleFilter",
    "onCommand:redmine-client.configureTicketStatusFilter",
    "onCommand:redmine-client.configureTicketTrackerFilter",
    "onCommand:redmine-client.configureTicketAssigneeFilter",
    "onCommand:redmine-client.configureTicketSort",
    "onCommand:redmine-client.configureTicketDueDateDisplay",
    "onCommand:redmine-client.resetTicketListSettings",
    "onCommand:redmine-client.configureEditorDefaultSubject",
    "onCommand:redmine-client.configureEditorDefaultDescription",
    "onCommand:redmine-client.configureEditorDefaultTracker",
    "onCommand:redmine-client.configureEditorDefaultPriority",
    "onCommand:redmine-client.configureEditorDefaultStatus",
    "onCommand:redmine-client.configureEditorDefaultDueDate",
    "onCommand:redmine-client.resetEditorDefaults",
    "onCommand:redmine-client.createTicket",
    "onCommand:redmine-client.createTicketFromList",
    "onCommand:redmine-client.createChildTicketFromList",
    "onCommand:redmine-client.addCommentFromComments",
    "onCommand:redmine-client.editComment",
    "onCommand:redmine-client.addComment",
    "onCommand:redmine-client.runOfflineSync",
    "onCommand:redmine-client.configureOfflineSyncMode",
    "onCommand:redmine-client.searchTickets",
    "onCommand:redmine-client.revealActiveTicket",
    "onCommand:redmine-client.focusTicketEditor",
    "onCommand:redmine-client.setApiKey",
    "onCommand:redmine-client.clearApiKey",
    "onCommand:redmine-client.showApiKeyStatus"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "redmine-clientActivity",
          "title": "Redmine Client",
          "icon": "media/redmine-client-activitybar.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "redmine-client.setApiKey",
        "title": "Redmine: Set API Key"
      },
      {
        "command": "redmine-client.clearApiKey",
        "title": "Redmine: Clear API Key"
      },
      {
        "command": "redmine-client.showApiKeyStatus",
        "title": "Redmine: Show API Key Status"
      },
      {
        "command": "redmine-client.loadMoreTickets",
        "title": "Redmine: Load More Tickets"
      },
      {
        "command": "redmine-client.refreshProjects",
        "title": "Redmine: Refresh Projects",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.refreshTickets",
        "title": "Redmine: Refresh Tickets",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.searchTickets",
        "title": "Redmine: Search Tickets",
        "icon": "$(search)"
      },
      {
        "command": "redmine-client.refreshComments",
        "title": "Redmine: Refresh Comments",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.collapseAllProjects",
        "title": "Redmine: Collapse All Projects",
        "icon": "$(collapse-all)"
      },
      {
        "command": "redmine-client.collapseAllTickets",
        "title": "Redmine: Collapse All Tickets",
        "icon": "$(collapse-all)"
      },
      {
        "command": "redmine-client.reloadProject",
        "title": "Redmine: Reload Project",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.reloadTicket",
        "title": "Redmine: Reload Ticket",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.reloadComment",
        "title": "Redmine: Reload Comment",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine-client.selectProject",
        "title": "Redmine: Select Project"
      },
      {
        "command": "redmine-client.toggleChildProjects",
        "title": "Redmine: Toggle Child Projects"
      },
      {
        "command": "redmine-client.openTicketPreview",
        "title": "Redmine: Open Ticket Preview"
      },
      {
        "command": "redmine-client.openExtraTicketEditor",
        "title": "Redmine: Open Ticket Editor (New)"
      },
      {
        "command": "redmine-client.configureTicketPriorityFilter",
        "title": "Redmine: Configure Ticket Priority Filter"
      },
      {
        "command": "redmine-client.configureTicketTitleFilter",
        "title": "Redmine: Configure Ticket Title Filter"
      },
      {
        "command": "redmine-client.configureTicketStatusFilter",
        "title": "Redmine: Configure Ticket Status Filter"
      },
      {
        "command": "redmine-client.configureTicketTrackerFilter",
        "title": "Redmine: Configure Ticket Tracker Filter"
      },
      {
        "command": "redmine-client.configureTicketAssigneeFilter",
        "title": "Redmine: Configure Ticket Assignee Filter"
      },
      {
        "command": "redmine-client.configureTicketSort",
        "title": "Redmine: Configure Ticket Sort"
      },
      {
        "command": "redmine-client.configureTicketDueDateDisplay",
        "title": "Redmine: Configure Ticket Due Date Display"
      },
      {
        "command": "redmine-client.resetTicketListSettings",
        "title": "Redmine: Reset Ticket Settings"
      },
      {
        "command": "redmine-client.configureEditorDefaultSubject",
        "title": "Redmine: Configure Editor Default Subject"
      },
      {
        "command": "redmine-client.configureEditorDefaultDescription",
        "title": "Redmine: Configure Editor Default Description"
      },
      {
        "command": "redmine-client.configureEditorDefaultTracker",
        "title": "Redmine: Configure Editor Default Tracker"
      },
      {
        "command": "redmine-client.configureEditorDefaultPriority",
        "title": "Redmine: Configure Editor Default Priority"
      },
      {
        "command": "redmine-client.configureEditorDefaultStatus",
        "title": "Redmine: Configure Editor Default Status"
      },
      {
        "command": "redmine-client.configureEditorDefaultDueDate",
        "title": "Redmine: Configure Editor Default Due Date"
      },
      {
        "command": "redmine-client.resetEditorDefaults",
        "title": "Redmine: Reset Editor Defaults"
      },
      {
        "command": "redmine-client.createTicket",
        "title": "Redmine: Create Ticket from Editor"
      },
      {
        "command": "redmine-client.createTicketFromList",
        "title": "Redmine: New Ticket",
        "icon": "$(add)"
      },
      {
        "command": "redmine-client.createChildTicketFromList",
        "title": "Redmine: Add Child Ticket",
        "icon": "$(add)"
      },
      {
        "command": "redmine-client.openProjectInBrowser",
        "title": "Redmine: Open Project in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "redmine-client.openTicketInBrowser",
        "title": "Redmine: Open Ticket in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "redmine-client.openCommentInBrowser",
        "title": "Redmine: Open Comment in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "redmine-client.editComment",
        "title": "Redmine: Edit Comment"
      },
      {
        "command": "redmine-client.addComment",
        "title": "Redmine: Add Comment"
      },
      {
        "command": "redmine-client.addCommentFromComments",
        "title": "Redmine: Add Comment",
        "icon": "$(add)"
      },
      {
        "command": "redmine-client.runOfflineSync",
        "title": "Redmine: Run Offline Sync",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "redmine-client.syncUnsyncedFile",
        "title": "Redmine: Sync This File",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "redmine-client.configureOfflineSyncMode",
        "title": "Redmine: Configure Offline Sync Mode"
      },
      {
        "command": "redmine-client.revealActiveTicket",
        "title": "Redmine: Focus Active Ticket in Tree"
      },
      {
        "command": "redmine-client.focusTicketEditor",
        "title": "Redmine: Focus Open Ticket Editor"
      },
      {
        "command": "redmine-client.syncToRedmine",
        "title": "Redmine: Sync to Redmine",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "redmine-client.syncOpenEditor",
        "title": "Redmine: Upload Open Editor",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "redmine-client.syncAllOpenEditors",
        "title": "Redmine: Upload All Open Editors",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "redmine-client.toggleRelevantTickets",
        "title": "Redmine: 絞り込み表示切替",
        "icon": "$(filter)"
      }
    ],
    "views": {
      "redmine-clientActivity": [
        {
          "id": "redmine-clientActivityDashboard",
          "name": "Dashboard",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/item/context": []
    },
    "configuration": {
      "title": "Redmine Client",
      "properties": {
        "redmine-client.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL of the Redmine instance."
        },
        "redmine-client.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Redmine API key for authentication. **Deprecated**: Use the `Redmine: Set API Key` command to store the key securely in VS Code SecretStorage instead."
        },
        "redmine-client.ignoreSSLErrors": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Ignore SSL certificate errors (e.g. for self-signed certificates). **For development/testing only. Do NOT enable in production.**"
        },
        "redmine-client.defaultProjectId": {
          "type": "string",
          "default": "",
          "description": "Default project identifier or ID used in ticket listing."
        },
        "redmine-client.selectedProjectId": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Last selected project ID (used for restoring selection)."
        },
        "redmine-client.selectedProjectName": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Last selected project name (used for restoring selection)."
        },
        "redmine-client.includeChildProjects": {
          "type": "boolean",
          "default": false,
          "description": "Include child projects when listing tickets."
        },
        "redmine-client.ticketListLimit": {
          "type": "number",
          "default": 50,
          "description": "Default number of tickets to load per request."
        },
        "redmine-client.editorStorageDirectory": {
          "type": "string",
          "default": "",
          "description": "Absolute path to store ticket editor files. When empty, the default workspace location is used."
        },
        "redmine-client.offlineSyncMode": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "manual"
          ],
          "description": "Sync mode for explicit sync commands. Auto sends to Redmine immediately, manual queues for batch sync. Ctrl+S always saves locally regardless of this setting."
        },
        "redmine-client.requestTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "HTTP request timeout in milliseconds (default: 30000ms = 30 seconds)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "node ./scripts/clean-test-output.js && tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unsafe": "bash ./scripts/vscode-test-nosandbox.sh"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
